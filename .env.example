# ════════════════════════════════════════════════════════════════════════════════
# SafeRide — Single Root Environment Template
#
# This is the ONE .env file for the entire monorepo.
# Every backend service, the web admin, and the seed script all read from here.
#
# Setup:
#   cp .env.example .env        ← copy and fill in real values
#   pnpm seed                   ← creates dev accounts in Firebase
#
# Mobile:
#   The EXPO_PUBLIC_ vars below are copied into mobile/.env automatically
#   by the sync-env script. Run `pnpm sync-env` after editing this file if
#   you change any EXPO_PUBLIC_ or GOOGLE_MAPS_API_KEY value.
#
# Production:
#   Each service container receives only its own subset of vars via AWS Secrets
#   Manager / ECS task definitions — this file is for local development only.
# ════════════════════════════════════════════════════════════════════════════════


# ── Shared: runtime + logging ─────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,exp://localhost:8081


# ── Firebase: project identity ────────────────────────────────────────────────
# Firebase Console → Project Settings → General
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app


# ── Firebase: Admin SDK (server-side only — NEVER expose to clients) ──────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as a single line.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}


# ── Service ports ─────────────────────────────────────────────────────────────
# Each service reads its own named var — no collisions when all share one file.
AUTH_SERVICE_PORT=4001
TENANT_SERVICE_PORT=4002
ROUTE_SERVICE_PORT=4003
TRIP_SERVICE_PORT=4004
LIVETRACK_PORT=4005


# ── livetrack-gateway: WebSocket keepalive ────────────────────────────────────
WS_PING_INTERVAL_MS=30000
WS_PONG_TIMEOUT_MS=10000


# ── Web admin: Firebase client config ────────────────────────────────────────
# Firebase Console → Project Settings → Your apps → Web app → SDK setup
# Only VITE_-prefixed vars are bundled into the browser — nothing else leaks.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_GOOGLE_MAPS_API_KEY=


# ── Web admin: backend service URLs ──────────────────────────────────────────
VITE_AUTH_SERVICE_URL=http://localhost:4001
VITE_TENANT_SERVICE_URL=http://localhost:4002
VITE_ROUTE_SERVICE_URL=http://localhost:4003
VITE_TRIP_SERVICE_URL=http://localhost:4004


# ── Mobile: Firebase client config ───────────────────────────────────────────
# Firebase Console → Project Settings → Your apps → Android app
# Note: FIREBASE_APP_ID here is the Android registration ID — different from the
# web app ID above.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app


# ── Google Maps ──────────────────────────────────────────────────────────────
# Two separate restricted API keys — never share a key between client and server.
#
# Key 1 — Android map tile rendering (MUST be in the app manifest)
#   Restrict to: Android apps → package in.saferide.app + release keystore SHA-1
#   Enable only: Maps SDK for Android
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
#
# Key 2 — Server-side Directions API (route-service only, never shipped to device)
#   Restrict to: IP addresses (your server/Cloud Run IPs)
#   Enable only: Directions API
GOOGLE_MAPS_DIRECTIONS_KEY=


# ── Mobile: backend service URLs ─────────────────────────────────────────────
# ⚠  Use your machine's LAN IP — localhost resolves to the device itself.
#    Find it: ipconfig (Windows) · ifconfig (Mac/Linux)
#    Example: http://10.0.0.192:4003
EXPO_PUBLIC_ROUTE_SERVICE_URL=http://<YOUR_LAN_IP>:4003
EXPO_PUBLIC_TRIP_SERVICE_URL=http://<YOUR_LAN_IP>:4004
EXPO_PUBLIC_AUTH_SERVICE_URL=http://<YOUR_LAN_IP>:4001
