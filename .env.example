# ════════════════════════════════════════════════════════════════════════════════
# SafeRide — Root Environment Template
#
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# After filling in .env, run:
#   pnpm sync-env        ← generates mobile/.env from this file
#   pnpm seed            ← creates dev accounts in Firebase
#
# ════════════════════════════════════════════════════════════════════════════════


# ── Firebase Project Identity ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app


# ── Firebase Admin SDK (server-side only — NEVER expose to clients) ───────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}


# ── Backend Services ──────────────────────────────────────────────────────────
# PORT is not set here — each service uses its own default port.
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173


# ── Firebase Client Config — Web Admin ────────────────────────────────────────
# Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_AUTH_SERVICE_URL=http://localhost:4001
VITE_TENANT_SERVICE_URL=http://localhost:4002
VITE_ROUTE_SERVICE_URL=http://localhost:4003
VITE_TRIP_SERVICE_URL=http://localhost:4004
VITE_GOOGLE_MAPS_API_KEY=


# ── Firebase Client Config — Mobile ──────────────────────────────────────────
# Firebase Console → Project Settings → Your apps → Android app
# Note: FIREBASE_APP_ID is the Android registration ID, different from web.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=


# ── Google Maps — Mobile Native Build ────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → Android API key
GOOGLE_MAPS_API_KEY=


# ── Mobile: Backend Service URLs ─────────────────────────────────────────────
# Use your machine's LAN IP (not localhost) — devices resolve localhost to themselves.
# Find it: ipconfig (Windows) · ifconfig (Mac/Linux)
EXPO_PUBLIC_AUTH_SERVICE_URL=http://<YOUR_LAN_IP>:4001
EXPO_PUBLIC_TRIP_SERVICE_URL=http://<YOUR_LAN_IP>:4004
