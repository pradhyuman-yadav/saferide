# ─────────────────────────────────────────────────────────────────────────────
# SafeRide — PROD environment template
# Copy to .env and fill in real values. Never commit .env.
# Used by: docker compose (all 5 services share this file)
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── Service ports ─────────────────────────────────────────────────────────────
AUTH_SERVICE_PORT=4001
TENANT_SERVICE_PORT=4002
ROUTE_SERVICE_PORT=4003
TRIP_SERVICE_PORT=4004
LIVETRACK_PORT=4005

# ── Internal service URLs (server-side only — never exposed to browser) ───────
# In Docker Compose, use service names as hostnames
TENANT_SERVICE_URL=http://tenant:4002
ROUTE_SERVICE_URL=http://route:4003
TRIP_SERVICE_URL=http://trip:4004
LIVETRACK_URL=http://livetrack:4005

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://saferide.co.in,https://admin.saferide.co.in,https://trysaferide.com

# ── Firebase (prod project: saferide-prod-a4336) ─────────────────────────────
# Paste the full service account JSON as a single line (no line breaks)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"saferide-prod-a4336",...}

FIREBASE_DATABASE_URL=https://saferide-prod-a4336-default-rtdb.asia-southeast1.firebasedatabase.app

# ── Google Maps (route-service — Directions API for polylines) ────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Expo Push Notifications (trip-service) ────────────────────────────────────
EXPO_PUSH_TOKEN=

# ── JWT (auth-service — RS256 key pair) ───────────────────────────────────────
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Web admin (Vite — build-time vars) ───────────────────────────────────────
VITE_AUTH_SERVICE_URL=https://api.saferide.co.in

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=saferide-prod-a4336.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=saferide-prod-a4336
VITE_FIREBASE_STORAGE_BUCKET=saferide-prod-a4336.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Mobile app (Expo — baked in at EAS build time) ───────────────────────────
EXPO_PUBLIC_AUTH_SERVICE_URL=https://api.saferide.co.in
EXPO_PUBLIC_ROUTE_SERVICE_URL=https://api.saferide.co.in
EXPO_PUBLIC_TRIP_SERVICE_URL=https://api.saferide.co.in
EXPO_PUBLIC_WS_URL=wss://ws.saferide.co.in

EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=saferide-prod-a4336.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=saferide-prod-a4336
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://saferide-prod-a4336-default-rtdb.asia-southeast1.firebasedatabase.app
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=saferide-prod-a4336.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:android:abc123
