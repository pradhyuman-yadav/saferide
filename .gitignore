# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
out/
.expo/
.expo-shared/
web-build/

# ── Environment & secrets ─────────────────────────────────────────────────────
# Single source of truth: root .env (read by all services via --env-file=../.env)
# .env.example files ARE committed — they are templates, not secrets.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ── Firebase / Google credentials ─────────────────────────────────────────────
*-service-account*.json
credentials.json
token.json
google-services.json
GoogleService-Info.plist
# Allow mobile Firebase config files — they contain only project identifiers, not secrets.
# The actual API keys are restricted by package name in Google Cloud Console.
!mobile/google-services.json
!mobile/GoogleService-Info.plist

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Test & coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Turborepo ─────────────────────────────────────────────────────────────────
.turbo/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Expo / React Native ───────────────────────────────────────────────────────
mobile/.expo/
mobile/android/
mobile/ios/
# mobile/.env is generated by `pnpm sync-env` — not committed
# mobile/.env.example IS committed (template only, no secrets)
mobile/.env
mobile/.env.local

# ── prod ───────────────────────────────────────────────────────
prod/
prod/.

# ── Submit credentials (never commit) ──────────────────────────
mobile/secrets/
mobile/credentials/

# ── Terraform ─────────────────────────────────────────────────
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/tfplan
infra/terraform/tfplan.out
*.tfplan

# ── Claude Code local settings ─────────────────────────────────
.claude/settings.local.json