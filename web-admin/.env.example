# Environment variables for web-admin are in the monorepo root .env.example
# See: ../.env.example
#
# Vite reads .env from the monorepo root (envDir: '../' in vite.config.ts).
# Only VITE_-prefixed vars are exposed to the browser bundle.
#
# Relevant vars for this app:
#   VITE_FIREBASE_API_KEY, VITE_FIREBASE_AUTH_DOMAIN, VITE_FIREBASE_PROJECT_ID
#   VITE_FIREBASE_STORAGE_BUCKET, VITE_FIREBASE_MESSAGING_SENDER_ID, VITE_FIREBASE_APP_ID
#   VITE_GOOGLE_MAPS_API_KEY
#   VITE_AUTH_SERVICE_URL, VITE_TENANT_SERVICE_URL
#   VITE_ROUTE_SERVICE_URL, VITE_TRIP_SERVICE_URL
