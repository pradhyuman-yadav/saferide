rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    // Resolve the caller's profile from the users collection.
    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // True when the caller's tenantId matches the document's tenantId.
    // Used to enforce DB-layer multi-tenancy as a second line of defence
    // behind the API-layer tenant guards.
    function sameTenantas(doc) {
      return request.auth != null
          && userProfile().tenantId == doc.data.tenantId;
    }

    // True when the caller has the super_admin role (cross-tenant reads).
    function isSuperAdmin() {
      return request.auth != null
          && userProfile().role == 'super_admin';
    }

    // ── Users ───────────────────────────────────────────────────────────────
    // Users may read only their own profile.
    // All writes go through the backend Admin SDK (bypasses these rules).
    match /users/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // ── Tenants ─────────────────────────────────────────────────────────────
    // super_admin may read any tenant; other roles may read only their own.
    // All writes go through the backend Admin SDK.
    match /tenants/{tenantId} {
      allow read:  if isSuperAdmin()
                   || (request.auth != null && userProfile().tenantId == tenantId);
      allow write: if false;
    }

    // ── Pending invites ─────────────────────────────────────────────────────
    // Exclusively managed by the backend Admin SDK.
    match /pendingInvites/{inviteKey} {
      allow read, write: if false;
    }

    // ── Route-service collections ───────────────────────────────────────────
    // Tenant isolation enforced here AND at the API layer.

    match /buses/{busId} {
      allow read:  if isSuperAdmin() || sameTenantas(resource);
      allow write: if false;
    }

    match /routes/{routeId} {
      allow read:  if isSuperAdmin() || sameTenantas(resource);
      allow write: if false;
    }

    match /stops/{stopId} {
      allow read:  if isSuperAdmin() || sameTenantas(resource);
      allow write: if false;
    }

    match /drivers/{driverId} {
      allow read:  if isSuperAdmin() || sameTenantas(resource);
      allow write: if false;
    }

    match /students/{studentId} {
      allow read:  if isSuperAdmin() || sameTenantas(resource);
      allow write: if false;
    }

    // ── Trip-service collections ────────────────────────────────────────────

    match /trips/{tripId} {
      allow read:  if isSuperAdmin() || sameTenantas(resource);
      allow write: if false;
    }

    // GPS telemetry — no direct client access; served via trip-service API only.
    match /gpsTelemetry/{docId} {
      allow read, write: if false;
    }

    // Webhooks — backend only (Admin SDK bypasses these rules).
    match /webhooks/{webhookId} {
      allow read, write: if false;
    }

    // Webhook delivery logs — backend only.
    match /webhookDeliveries/{deliveryId} {
      allow read, write: if false;
    }

    // ── Deny everything else by default ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
