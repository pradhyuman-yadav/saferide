{
  "name": "saferide-livetrack-gateway",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":          "tsx watch --env-file=../.env src/index.ts",
    "build":        "tsc",
    "start":        "node --env-file=../.env dist/index.js",
    "typecheck":    "tsc --noEmit",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@saferide/firebase-admin": "workspace:*",
    "@saferide/logger":         "workspace:*",
    "@saferide/types":          "workspace:*",
    "ws":                       "^8.18.0",
    "zod":                      "^3.23.8"
  },
  "devDependencies": {
    "@types/node":    "^22.0.0",
    "@types/ws":      "^8.5.13",
    "@vitest/coverage-v8": "^2.1.0",
    "tsx":            "^4.19.0",
    "typescript":     "~5.5.3",
    "vitest":         "^2.1.0"
  }
}
