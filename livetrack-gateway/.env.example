# Environment variables for livetrack-gateway are in the monorepo root .env.example
# See: ../.env.example
#
# Relevant vars for this service:
#   NODE_ENV, LOG_LEVEL, CORS_ORIGINS
#   FIREBASE_SERVICE_ACCOUNT_JSON
#   LIVETRACK_PORT (default: 4005)
#   WS_PING_INTERVAL_MS (default: 30000)
#   WS_PONG_TIMEOUT_MS  (default: 10000)
