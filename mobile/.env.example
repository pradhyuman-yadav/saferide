# Environment variables for the mobile app are in the monorepo root .env.example
# See: ../.env.example
#
# mobile/.env is generated from the root .env by running: pnpm sync-env
# Do not edit mobile/.env directly — changes will be overwritten.
#
# Relevant vars for this app:
#   EXPO_PUBLIC_FIREBASE_API_KEY, EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN
#   EXPO_PUBLIC_FIREBASE_PROJECT_ID, EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET
#   EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID, EXPO_PUBLIC_FIREBASE_APP_ID
#   EXPO_PUBLIC_FIREBASE_DATABASE_URL
#   GOOGLE_MAPS_API_KEY, EXPO_PUBLIC_GOOGLE_MAPS_API_KEY
#   EXPO_PUBLIC_AUTH_SERVICE_URL, EXPO_PUBLIC_ROUTE_SERVICE_URL, EXPO_PUBLIC_TRIP_SERVICE_URL
